generator client {
  provider = "prisma-client-js"
}

//toutes les données sont stockées dans le fichier dev.db (pas de serveur, localhost, root, pdp ) 
//SQLite est une base de données embarquée (embedded) et non pas serveur comme mysql et postgres 
datasource db {
  provider = "sqlite"

}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique
  role  Role   @default(USER)
  cvs   Cv[]
}

model Skill {
  id          String @id @default(uuid())
  designation String
  cvs         Cv[]   @relation("CvSkills")
}

model Cv {
  id      String  @id @default(uuid())
  name    String
  age     Int
  job     String
  owner   User    @relation(fields: [ownerId], references: [id])
  ownerId String
  skills  Skill[] @relation("CvSkills")
}

enum Role {
  USER
  ADMIN
}
