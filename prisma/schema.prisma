generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}


model User {
  id    Int  @id @default(autoincrement())
  name  String
  email String @unique
  role  Role   @default(USER)
  cvs   Cv[]
}

model Skill {
  id          Int @id @default(autoincrement())
  designation String
  cvs         Cv[]   @relation("CvSkills")
}

model Cv {
  id      Int  @id @default(autoincrement())
  name    String
  age     Int
  job     String
  owner   User    @relation(fields: [ownerId], references: [id])
  ownerId Int
  skills  Skill[] @relation("CvSkills")
}

enum Role {
  USER
  ADMIN
}
